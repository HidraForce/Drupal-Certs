{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "web": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "public" }],
            "styles": ["src/styles.css", "src/admin.css"]
          },
          "configurations": {
            "production": { "budgets": [{ "type": "initial", "maximumWarning": "650kB", "maximumError": "850kB" }], "outputHashing": "all" },
            "development": { "optimization": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": { "builder": "@angular/build:dev-server", "configurations": { "development": { "buildTarget": "web:build:development" } }, "defaultConfiguration": "development" }
      }
    }
  }
}
